{
  "name": "@mdn/mcp",
  "version": "0.0.1",
  "repository": "https://github.com/mdn/mcp",
  "type": "module",
  "author": "MDN Web Docs",
  "license": "MPL-2.0",
  "scripts": {
    "start": "node index.js",
    "dev": "node scripts/dev.js",
    "dev:server": "nodemon index.js",
    "dev:inspector": "mcp-inspector --config mcp.json",
    "tsc": "tsc",
    "test": "node --test --experimental-test-coverage --test-coverage-lines 100 --test-coverage-exclude 'test/**/*' 'test/**/*.test.js'",
    "test:watch": "node --test --watch 'test/**/*.test.js'",
    "glean:generate": "glean translate glean/metrics.yaml -f javascript -o glean/generated/ && glean translate glean/metrics.yaml -f typescript -o glean/generated/ && sed -i 's/ DO NOT COMMIT\\.//g' glean/generated/*"
  },
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.8.0"
    }
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.1.0",
    "@mdn/fred": "^2.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/glean": "^2.0.5",
    "@sentry/node": "^10.65.0",
    "express": "^5.1.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/turndown": "^5.0.6",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-unicorn": "^65.0.1",
    "lefthook": "^2.1.10",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "undici": "^8.0.2",
    "zod": "^4.4.3"
  }
}
